# SupplyIQ - Gradio UI image.

FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir gradio==4.44.1 httpx==0.27.2

COPY src/ui/ ./src/ui/
COPY src/__init__.py ./src/__init__.py

ENV PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    SUPPLYIQ_API_URL=http://api:8000

EXPOSE 7860

CMD ["python", "src/ui/app.py"]
